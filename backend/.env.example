# ===========================================
# SCANPY PLATFORM - ENVIRONMENT CONFIGURATION
# ===========================================
# 
# IMPORTANT: This is a template file for development.
# Copy this file to .env and customize values.
# 
# For production:
# - Use strong, randomly generated passwords
# - Never commit .env to version control
# - Consider using secret management tools
# ===========================================

# Environment
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# Security (CHANGE THESE IN PRODUCTION!)
SECRET_KEY=dev-secret-key-change-in-production
ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.com

# Database Configuration
POSTGRES_USER=scanpy_user
POSTGRES_PASSWORD=changeme_in_production
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=scanpy_db

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Storage
DATA_DIR=/path/to/data/directory

# Performance & Limits
MAX_CONCURRENT_JOBS=5
JOB_TIMEOUT_SECONDS=3600

# Monitoring (optional)
ENABLE_METRICS=false
SENTRY_DSN=

# ===========================================
# PRODUCTION DEPLOYMENT NOTES
# ===========================================
# 
# 1. Generate secure SECRET_KEY:
#    python -c "import secrets; print(secrets.token_urlsafe(32))"
# 
# 2. Set ENVIRONMENT=production
# 
# 3. Set DEBUG=false
# 
# 4. Use strong database passwords
# 
# 5. Configure Redis password if using external Redis
# 
# 6. Set proper DATA_DIR path for your server
# 
# 7. Adjust MAX_CONCURRENT_JOBS based on server capacity
# 
# 8. Enable monitoring with SENTRY_DSN for error tracking
# 
# ===========================================