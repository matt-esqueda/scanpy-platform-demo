# ===========================================
# SCANPY PLATFORM - ENVIRONMENT CONFIGURATION
# ===========================================
# 
# IMPORTANT: This is a template file for development.
# Copy this file to .env and customize values.
# 
# For production:
# - Use strong, randomly generated passwords
# - Never commit .env to version control
# - Consider using secret management tools
# ===========================================

# Database Configuration
POSTGRES_USER=scanpy_user
POSTGRES_PASSWORD=changeme_in_production
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=scanpy_db

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379

# Application Settings
DEBUG=True
LOG_LEVEL=INFO

# Security (add later when implementing auth)
# SECRET_KEY=generate_random_key_here
# JWT_SECRET=generate_random_key_here